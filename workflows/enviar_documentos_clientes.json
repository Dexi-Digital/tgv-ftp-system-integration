    {
      "parameters": {
        "jsCode": "function numeroRandomicoIntervalo(min, max) {\n  return Math.floor(Math.random() * (max - min + 1) + min);\n}\n\nfor (const item of items) {\n  item.json.numeroRandomico = numeroRandomicoIntervalo(5, 15);\n}\n\nreturn items;"
      },
