      "name": "extrair_contatos"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = new Set();\nconst cleaned = [];\n\nfor (const item of items) {\n  let phone = String(\n    item.json.Contato ||\n    item.json.contato ||\n    item.json.telefone ||\n    item.json.Telefone ||\n    ''\n  ).replace(/[^0-9]/g, '');\n\n  // Adiciona prefixo 55 (Brasil) se necessario\n  if (!phone.startsWith('55')) {\n    phone = '55' + phone;\n  }\n\n  // Ignora duplicados e numeros invalidos (min 12 digitos: 55 + DDD + numero)\n  if (seen.has(phone) || phone.length < 12) continue;\n  seen.add(phone);\n\n  // Extrai primeiro nome em Capital Case\n  const nomeCompleto = item.json.NomeCliente || item.json.nome_cliente || '';\n  const primeiroNome = nomeCompleto.split(' ')[0];\n  const nomeFormatado = primeiroNome.charAt(0).toUpperCase() + primeiroNome.slice(1).toLowerCase();\n\n  cleaned.push({\n    json: {\n      telefone: phone,\n      nome_cliente: nomeFormatado,\n      nome_completo: nomeCompleto,\n      empreendimento: item.json.NomeEmpreendimento || item.json.nome_empreendimento || '',\n      unidade: item.json.DescricaoUnidades || item.json.descricao_unidades || ''\n    }\n  });\n}\n\nreturn cleaned;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        0
      ],
      "id": "c7d1e2f3-a4b5-4c6d-8e9f-100000000003",
